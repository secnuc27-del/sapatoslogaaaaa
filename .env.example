# Variáveis de Ambiente — Lumière
# Copie este arquivo para .env.local e preencha com seus dados reais

# PostgreSQL (Supabase)
# Vá em supabase.com → Project Settings → Database → Connection String → URI
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require"

# JWT — Gere uma chave secreta forte:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="COLOQUE_AQUI_UMA_CHAVE_SECRETA_FORTE_DE_64_CARACTERES"

# WhatsApp da loja (só números, sem espaços ou traços)
NEXT_PUBLIC_WHATSAPP="5599999999999"

# Nome da loja
NEXT_PUBLIC_STORE_NAME="Lumière"
